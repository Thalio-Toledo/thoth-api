  "components": {
    "schemas": {
      "AssessementDTO": {
        "required": [
          "profileId",
          "title",
          "assessorUserId",
          "startDate",
          "endDate"
        ],
        "type": "object",
        "properties": {
          "profileId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "assessorUserId": {
            "type": "string",
            "format": "uuid"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AssessmentSource": {
        "type": "integer"
      },
      "Level": {
        "type": "integer"
      },
      "MetricDTO": {
        "required": [
          "name",
          "description",
          "type",
          "weight",
          "source",
          "periodicity",
          "rule"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "type": {
            "$ref": "#/components/schemas/MetricType"
          },
          "weight": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "source": {
            "$ref": "#/components/schemas/AssessmentSource"
          },
          "periodicity": {
            "$ref": "#/components/schemas/Periodicity"
          },
          "rule": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "MetricType": {
        "type": "integer"
      },
      "Periodicity": {
        "type": "integer"
      },
      "ProfileDTO": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "SkillDTO": {
        "required": [
          "profileId",
          "name",
          "level"
        ],
        "type": "object",
        "properties": {
          "profileId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "level": {
            "$ref": "#/components/schemas/Level"
          }
        }
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "temperatureF": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "summary": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Profile"
    },
    {
      "name": "WeatherForecast"
    }
  ]
